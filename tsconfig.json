{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/adapters" },
    { "path": "./packages/doctor" },
    { "path": "./packages/planner" },
    { "path": "./packages/cli" }
  ]
}
